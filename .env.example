# Copia este archivo como .env y completa los valores

# Token de Twilio (lo encontras en twilio.com > Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de tu Google Spreadsheet
# Es la parte de la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Ruta al archivo JSON de credenciales de Google
GOOGLE_CREDENTIALS_FILE= credentials.json

# Puerto del servidor (opcional, por defecto 5000)
PORT=5000
